Bootstrap: docker
From: python:3.12-slim-bookworm

# LoopCoder sandbox container — restricted execution environment for the
# agent's tool calls (run_shell, run_tests, etc.). Built inside the Bundle
# VM. Designed to be small (<1GB) so it stages quickly to /scratch.

%post
    set -eux
    apt-get update
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        curl \
        ca-certificates \
        ripgrep \
        jq \
        less
    rm -rf /var/lib/apt/lists/*

    # Common Python tools the agent will use
    pip install --no-cache-dir \
        pytest \
        pytest-cov \
        ruff \
        mypy

    mkdir -p /workspace /cache
    chmod 1777 /workspace /cache

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export HOME=/cache

%runscript
    exec "$@"

%labels
    org.loopcoder.role sandbox
