# vLLM config tuned for the tiny model (single GPU or CPU dev hosts).

serving:
  host: 127.0.0.1
  port: 8000
  api_key: ""

engine:
  tensor_parallel_size: 1            # single GPU
  max_model_len: 32768
  max_num_seqs: 4
  gpu_memory_utilization: 0.85
  quantization: null                  # tiny model is BF16 already
  enable_prefix_caching: true
  enable_chunked_prefill: true
  swap_space_gb: 0
  kv_cache_dtype: auto
  trust_remote_code: false

env:
  HF_HUB_OFFLINE: "1"
  TRANSFORMERS_OFFLINE: "1"
  VLLM_USE_V1: "1"

systemd:
  restart: on-failure
  restart_sec: 15
