# LoopCoder one-command deploy config.
# Used by scripts/deploy.sh as:
#     bash scripts/deploy.sh --config deploy.yaml
#
# What deploy.sh does, given this file:
#   1. SSH probe to <target> (passwordless key required)
#   2. rsync the entire bundle (apt + wheels + containers + source)
#      to <remote_bundle> on the target
#   3. apt-get install -y ./*.deb  (apptainer + deps; NOT dpkg)
#   4. Optional: stage a model from <model.source> into <model.dest> on
#      the target (or skip if the model is uploaded out-of-band)
#   5. bash setup.sh on the target
#   6. systemctl status vllm + loopcoder report
# All steps are idempotent; rerunning resumes from the last good stage.

target:
  # ssh user@host. Must be passwordless key auth.
  host: ubuntu@b300.example.org
  # Optional. ssh -i, ssh ProxyCommand, etc.
  ssh_opts: []                       # e.g. ["-J", "jump@bastion"]
  # Where to drop the bundle on the remote. Read-only-ish; setup.sh
  # uses this as $BUNDLE_ROOT.
  remote_bundle: /models
  # Sudo prefix on remote. Empty string disables; default = "sudo".
  sudo_remote: sudo

bundle:
  # Local bundle directory. Defaults to LoopCoder/output/bundle when
  # absent; falls back to /data/loopcoder-bundle if that's empty.
  local_dir: /data/loopcoder-bundle

flags:
  # Pass through to setup.sh on the remote.
  skip_gpu_stages: false             # true = Test VM mode (no nvidia-smi)
  skip_model_stage: false            # true = leave /scratch/models alone

# --- Multi-model (preferred) ---------------------------------------
# List every model you want available. scripts/fetch-models.sh reads
# this, downloads each from HuggingFace in one shot, and verifies it
# against the catalog. setup.sh then brings up one vllm@<key> systemd
# instance per model (each on its own port). LoopCoder talks to
# `default_model` unless a plan/request overrides it.
#
# Each entry:
#   key   short name used in plan.yaml / requests + the systemd
#         instance name (vllm@<key>)
#   id    HuggingFace repo id (serving params — quant / tp / max_len /
#         tool parser — auto-resolved from the catalog)
#   port  vLLM port for this model's instance (must be unique)
models:
  - key: fast
    id: Qwen/Qwen2.5-Coder-7B-Instruct-AWQ
    port: 8001
  - key: big
    id: Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8
    port: 8002

# Model LoopCoder uses when a plan/request doesn't name one.
default_model: fast

# --- Single-model (legacy, still honored when `models:` is absent) -
# Stage one model in the deploy step. Modes:
#   none   — model already on the target (OOB upload)
#   rsync  — local copy → target via rsync
#   hf     — download on the target (target needs internet; rare on B300)
model:
  mode: none                          # none | rsync | hf
  local_path: /data/models/Qwen2.5-Coder-1.5B-Instruct
  remote_path: /scratch/models/Qwen2.5-Coder-1.5B-Instruct
  hf_id: Qwen/Qwen2.5-Coder-1.5B-Instruct
